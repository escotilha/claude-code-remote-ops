{
  "name": "ssh-mcp-server",
  "version": "1.2.0",
  "description": "MCP server that lets an LLM agent run commands and transfer files on remote hosts over SSH, with named connections and command allow/deny lists.",
  "type": "module",
  "bin": {
    "ssh-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/**/*.test.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ssh2": "^1.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.0",
    "typescript": "^5.5.0"
  }
}
